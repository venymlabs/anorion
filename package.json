{
  "name": "anorion",
  "version": "0.2.5",
  "description": "The open-source agent gateway — connect any LLM to any channel",
  "keywords": [
    "ai",
    "agent",
    "gateway",
    "llm",
    "telegram",
    "chatbot",
    "orchestration",
    "openai",
    "anthropic",
    "claude",
    "gpt"
  ],
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "anorion": "./bin/anorion.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "scripts/",
    "agents/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:cli": "bun build src/cli/index.ts --outfile bin/anorion.js --target node",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "bun run build:cli",
    "cli": "bun run src/cli/index.ts",
    "setup": "bun run scripts/setup.ts",
    "doctor": "bun run scripts/cli.ts doctor"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.41",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "ai": "^6.0.116",
    "discord.js": "^14.26.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.41.1",
    "hono": "^4.12.8",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
